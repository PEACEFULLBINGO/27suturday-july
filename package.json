{
  "name": "studyflow-orbit",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered student productivity cockpit — timetable, focus timer, notes, exam tracker, and an AI study coach.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
